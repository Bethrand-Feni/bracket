{
  "name": "bracket-tournament-creator",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/logs/dev.log vite",
    "build": "WRANGLER_LOG_PATH=.wrangler/logs/build.log vite build",
    "start": "WRANGLER_LOG_PATH=.wrangler/logs/preview.log vite preview",
    "deploy": "npm run build && wrangler deploy",
    "test:unit": "vitest run --config vitest.config.ts",
    "test": "npm run build && node --test tests/rendered-html.test.mjs",
    "lint": "eslint . --ignore-pattern dist",
    "db:generate": "drizzle-kit generate"
  },
  "dependencies": {
    "@fontsource/fredoka": "^5.2.10",
    "@fontsource/poppins": "^5.2.7",
    "drizzle-orm": "0.45.2",
    "jose": "^6.2.3",
    "vue": "^3.5.40",
    "vue-router": "^4.6.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.37.1",
    "@cloudflare/workers-types": "^4.20260702.1",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "22.19.19",
    "@typescript-eslint/parser": "^8.65.0",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vue/test-utils": "^2.4.11",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-plugin-vue": "^10.10.0",
    "fake-indexeddb": "^6.2.5",
    "happy-dom": "^20.11.1",
    "tailwindcss": "^4.3.3",
    "typescript": "5.9.3",
    "vite": "8.0.13",
    "vitest": "^4.1.10",
    "vue-eslint-parser": "^10.4.1",
    "wrangler": "4.92.0"
  },
  "type": "module"
}
